<%- include('partials/header') %>

<h1 class="page-title">مدیریت کاربران</h1>

<div class="glass-card">
  <table>
    <thead>
      <tr>
        <th>شناسه دیتابیس</th>
        <th>آیدی تلگرام</th>
        <th>نام کاربری</th>
        <th>تعداد رزومه</th>
        <th>تاریخ عضویت</th>
      </tr>
    </thead>
    <tbody>
      <% if (users && users.length > 0) { %>
        <% users.forEach(user => { %>
          <tr>
            <td><%= user.id %></td>
            <td dir="ltr"><%= user.telegramId %></td>
            <td dir="ltr">@<%= user.username || '---' %></td>
            <td><span class="badge"><%= user._count.resumes %> رزومه</span></td>
            <td><%= new Date(user.createdAt).toLocaleDateString('fa-IR') %></td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="5" style="text-align: center;">هیچ کاربری یافت نشد.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('partials/footer') %>
