<!DOCTYPE html>
<html lang="<%= data.language === 'en' ? 'en' : 'fa' %>">
<head>
  <meta charset="UTF-8">
  <title>Resume - Creative</title>
  <%- include('styles') %>
  <style>
    .creative-resume {
      padding: 0;
      max-width: 210mm;
      margin: auto;
      font-family: var(--font-en-body);
      color: #333;
      background: #fafafa;
    }
    .header {
      background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
      color: white;
      padding: 50px;
      text-align: left;
      clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%);
      margin-bottom: 30px;
    }
    body.lang-fa .header {
      text-align: right;
      clip-path: polygon(0 0, 100% 0, 100% 100%, 0 85%);
    }
    .header h1 {
      font-size: 48px;
      margin: 0;
      font-family: var(--font-en-heading);
      letter-spacing: -1px;
    }
    .header h2 {
      font-size: 22px;
      margin: 5px 0 20px;
      font-weight: 400;
      opacity: 0.9;
    }
    .contact-info {
      font-size: 14px;
      opacity: 0.9;
    }
    .main-body {
      padding: 0 50px 50px 50px;
      column-count: 2;
      column-gap: 40px;
    }
    .section {
      break-inside: avoid;
      margin-bottom: 30px;
      background: white;
      padding: 25px;
      border-radius: 15px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
    .section-title {
      font-size: 18px;
      color: #f5576c;
      margin: 0 0 20px 0;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2px;
      display: inline-block;
      border-bottom: 3px solid #f093fb;
      padding-bottom: 5px;
    }
    .item {
      margin-bottom: 20px;
    }
    .item-title {
      font-size: 16px;
      font-weight: 700;
      margin: 0;
      color: #333;
    }
    .item-subtitle {
      font-size: 14px;
      color: #f5576c;
      margin: 2px 0;
      font-weight: 500;
    }
    .item-date {
      font-size: 12px;
      color: #999;
      background: #f0f0f0;
      padding: 2px 8px;
      border-radius: 10px;
      display: inline-block;
      margin-top: 5px;
    }
    .item-desc {
      font-size: 13.5px;
      line-height: 1.6;
      margin-top: 10px;
      color: #555;
      padding-inline-start: 18px;
    }
    .skill-tag {
      background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
      color: white;
      padding: 5px 12px;
      border-radius: 20px;
      font-size: 12px;
      display: inline-block;
      margin: 4px;
      font-weight: 500;
    }
  </style>
</head>
<body class="lang-<%= data.language %>">
  <div class="page creative-resume">
    <div class="header">
      <h1><%= data.fullName %></h1>
      <h2><%= data.jobTitle %></h2>
      <div class="contact-info">
        <% if (data.email) { %><span><%= data.email %></span> | <% } %>
        <% if (data.phone) { %><span dir="ltr"><%= data.phone %></span> | <% } %>
        <% if (data.location) { %><span><%= data.location %></span><% } %>
      </div>
    </div>

    <div class="main-body">
      <% if (data.summary) { %>
      <div class="section">
        <h3 class="section-title"><%= data.language === 'en' ? 'Profile' : 'پروفایل' %></h3>
        <p style="font-size: 14px; line-height: 1.6; color:#555; margin:0;"><%= data.summary %></p>
      </div>
      <% } %>

      <% if (data.experience && data.experience.length > 0) { %>
      <div class="section">
        <h3 class="section-title"><%= data.language === 'en' ? 'Experience' : 'تجربیات' %></h3>
        <% data.experience.forEach(exp => { %>
          <div class="item">
            <p class="item-title"><%= exp.title %></p>
            <p class="item-subtitle"><%= exp.company %></p>
            <span class="item-date"><%= exp.date %></span>
            <ul class="item-desc">
              <% exp.descriptions.forEach(desc => { %><li><%= desc %></li><% }) %>
            </ul>
          </div>
        <% }) %>
      </div>
      <% } %>

      <% if (data.education && data.education.length > 0) { %>
      <div class="section">
        <h3 class="section-title"><%= data.language === 'en' ? 'Education' : 'تحصیلات' %></h3>
        <% data.education.forEach(edu => { %>
          <div class="item">
            <p class="item-title"><%= edu.degree %></p>
            <p class="item-subtitle"><%= edu.university %></p>
            <span class="item-date"><%= edu.date %></span>
          </div>
        <% }) %>
      </div>
      <% } %>

      <% if (data.skills && data.skills.length > 0) { %>
      <div class="section">
        <h3 class="section-title"><%= data.language === 'en' ? 'Skills' : 'مهارت‌ها' %></h3>
        <% data.skills.forEach(skillGroup => { %>
          <div style="margin-bottom:15px;">
            <p style="font-size:14px; font-weight:600; margin:0 0 5px 0;"><%= skillGroup.category %></p>
            <div>
              <% skillGroup.items.forEach(item => { %>
                <span class="skill-tag"><%= item %></span>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
      <% } %>

      <% if (data.projects && data.projects.length > 0) { %>
      <div class="section">
        <h3 class="section-title"><%= data.language === 'en' ? 'Projects' : 'پروژه‌ها' %></h3>
        <% data.projects.forEach(proj => { %>
          <div class="item">
            <p class="item-title"><%= proj.name %></p>
            <p class="item-subtitle"><%= proj.role %></p>
            <ul class="item-desc">
              <% proj.descriptions.forEach(desc => { %><li><%= desc %></li><% }) %>
            </ul>
          </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>
</body>
</html>
