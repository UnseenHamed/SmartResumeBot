<!DOCTYPE html>
<html lang="<%= data.language === 'en' ? 'en' : 'fa' %>">
<head>
  <meta charset="UTF-8">
  <title>Resume — Creative</title>
  <%- include('styles') %>
  <style>
    .creative-resume {
      padding: 0;
      max-width: 210mm;
      margin: auto;
      background: #fafbfc;
    }
    
    /* ─── Header ─── */
    .header {
      background: linear-gradient(135deg, #4f46e5 0%, #0ea5e9 100%);
      color: white;
      padding: 45px 50px 55px;
      position: relative;
    }
    .header::after {
      content: '';
      position: absolute;
      bottom: -20px;
      left: 0;
      right: 0;
      height: 40px;
      background: linear-gradient(135deg, #4f46e5 0%, #0ea5e9 100%);
      border-radius: 0 0 50% 50% / 0 0 100% 100%;
    }
    .header h1 {
      font-size: 40px;
      margin: 0;
      font-weight: 700;
      letter-spacing: -0.5px;
    }
    .header h2 {
      font-size: 17px;
      margin: 6px 0 20px;
      font-weight: 400;
      opacity: 0.9;
    }
    .header .contact-row {
      display: flex;
      flex-wrap: wrap;
      gap: 5px 18px;
      font-size: 12px;
      opacity: 0.9;
    }
    .header .contact-row .item {
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .header .contact-row .ic svg { display: block; }

    /* ─── Body ─── */
    .body-content {
      padding: 40px 50px 50px;
    }

    .section {
      background: white;
      padding: 25px 28px;
      border-radius: 14px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.04);
      margin-bottom: 20px;
    }
    .section-title {
      font-size: 15px;
      color: #4f46e5;
      margin: 0 0 18px 0;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .section-title::before {
      content: '';
      width: 4px;
      height: 18px;
      background: linear-gradient(to bottom, #4f46e5, #0ea5e9);
      border-radius: 2px;
      display: inline-block;
    }

    .entry { margin-bottom: 18px; }
    .entry:last-child { margin-bottom: 0; }
    .entry-title {
      font-size: 15px;
      font-weight: 600;
      margin: 0;
      color: #1e293b;
    }
    .entry-sub {
      font-size: 13px;
      color: #4f46e5;
      margin: 2px 0 0 0;
      font-weight: 500;
    }
    .entry-date {
      font-size: 11px;
      color: #94a3b8;
      background: #f1f5f9;
      padding: 2px 10px;
      border-radius: 12px;
      display: inline-block;
      margin-top: 5px;
      font-weight: 500;
    }
    .entry-desc {
      font-size: 13px;
      line-height: 1.6;
      margin-top: 8px;
      color: #475569;
      padding-inline-start: 16px;
    }
    .entry-desc li { margin-bottom: 3px; }

    .summary-text {
      font-size: 13.5px;
      line-height: 1.7;
      color: #475569;
      margin: 0;
    }

    /* ─── Skills ─── */
    .skill-group { margin-bottom: 14px; }
    .skill-group:last-child { margin-bottom: 0; }
    .skill-group-title {
      font-size: 13px;
      font-weight: 600;
      color: #334155;
      margin: 0 0 8px 0;
    }
    .skill-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .skill-tag {
      background: linear-gradient(135deg, #4f46e5, #0ea5e9);
      color: white;
      padding: 4px 14px;
      border-radius: 20px;
      font-size: 11px;
      font-weight: 500;
    }

    /* ─── Two Columns ─── */
    .two-col-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
  </style>
</head>
<body class="lang-<%= data.language %>">
  <div class="page creative-resume">
    <div class="header">
      <h1><%= data.fullName || '' %></h1>
      <h2><%= data.jobTitle || '' %></h2>
      <div class="contact-row">
        <% if (data.email) { %><span class="item"><span class="ic"><%- icon('email') %></span> <%= data.email %></span><% } %>
        <% if (data.phone) { %><span class="item"><span class="ic"><%- icon('phone') %></span> <span dir="ltr"><%= data.phone %></span></span><% } %>
        <% if (data.location) { %><span class="item"><span class="ic"><%- icon('location') %></span> <%= data.location %></span><% } %>
        <% if (data.socialLinks && data.socialLinks.length > 0) { data.socialLinks.forEach(link => { %>
          <span class="item"><span class="ic"><%- icon(link.name) %></span> <%= link.url %></span>
        <% }) } %>
      </div>
    </div>

    <div class="body-content">
      <% if (data.summary) { %>
      <div class="section">
        <h3 class="section-title"><%= data.language === 'en' ? 'Profile' : 'پروفایل' %></h3>
        <p class="summary-text"><%= data.summary %></p>
      </div>
      <% } %>

      <% if (data.experience && data.experience.length > 0) { %>
      <div class="section">
        <h3 class="section-title"><%= data.language === 'en' ? 'Experience' : 'تجربیات' %></h3>
        <% data.experience.forEach(exp => { %>
          <div class="entry">
            <p class="entry-title"><%= exp.title %></p>
            <p class="entry-sub"><%= exp.company %></p>
            <span class="entry-date"><%= exp.date %></span>
            <ul class="entry-desc">
              <% (exp.descriptions || []).forEach(desc => { %><li><%= desc %></li><% }) %>
            </ul>
          </div>
        <% }) %>
      </div>
      <% } %>

      <div class="two-col-grid">
        <div>
          <% if (data.education && data.education.length > 0) { %>
          <div class="section">
            <h3 class="section-title"><%= data.language === 'en' ? 'Education' : 'تحصیلات' %></h3>
            <% data.education.forEach(edu => { %>
              <div class="entry">
                <p class="entry-title"><%= edu.degree %></p>
                <p class="entry-sub"><%= edu.university %></p>
                <span class="entry-date"><%= edu.date %></span>
              </div>
            <% }) %>
          </div>
          <% } %>

          <% if (data.knownLanguages && data.knownLanguages.length > 0) { %>
          <div class="section">
            <h3 class="section-title"><%= data.language === 'en' ? 'Languages' : 'زبان‌ها' %></h3>
            <% data.knownLanguages.forEach(lang => { %>
              <div class="entry" style="margin-bottom:8px;">
                <span style="font-size:13px;font-weight:500;color:#334155;"><%= lang.name %></span>
                <span style="font-size:12px;color:#94a3b8;"> — <%= lang.level %></span>
              </div>
            <% }) %>
          </div>
          <% } %>
        </div>

        <div>
          <% if (data.skills && data.skills.length > 0) { %>
          <div class="section">
            <h3 class="section-title"><%= data.language === 'en' ? 'Skills' : 'مهارت‌ها' %></h3>
            <% data.skills.forEach(skillGroup => { %>
              <div class="skill-group">
                <p class="skill-group-title"><%= skillGroup.category %></p>
                <div class="skill-tags">
                  <% skillGroup.items.forEach(item => { %>
                    <span class="skill-tag"><%= item %></span>
                  <% }) %>
                </div>
              </div>
            <% }) %>
          </div>
          <% } %>
        </div>
      </div>

      <% if (data.projects && data.projects.length > 0) { %>
      <div class="section">
        <h3 class="section-title"><%= data.language === 'en' ? 'Projects' : 'پروژه‌ها' %></h3>
        <% data.projects.forEach(proj => { %>
          <div class="entry">
            <p class="entry-title"><%= proj.name %></p>
            <p class="entry-sub"><%= proj.role %><% if (proj.techStack) { %> · <%= proj.techStack %><% } %></p>
            <ul class="entry-desc">
              <% (proj.descriptions || []).forEach(desc => { %><li><%= desc %></li><% }) %>
            </ul>
          </div>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>
</body>
</html>
