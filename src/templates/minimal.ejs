<!DOCTYPE html>
<html lang="<%= data.language === 'en' ? 'en' : 'fa' %>">
<head>
  <meta charset="UTF-8">
  <title>Resume — Minimal</title>
  <%- include('styles') %>
  <style>
    .minimal-resume {
      padding: 55px 60px;
      max-width: 210mm;
      margin: auto;
      color: #1a1a1a;
    }
    
    /* ─── Header ─── */
    .header { margin-bottom: 40px; }
    .header h1 {
      font-size: 44px;
      font-weight: 300;
      margin: 0;
      letter-spacing: -1px;
      color: #111;
    }
    .header h2 {
      font-size: 14px;
      color: #999;
      margin: 6px 0 22px;
      font-weight: 400;
      text-transform: uppercase;
      letter-spacing: 3px;
    }
    .contact-row {
      display: flex;
      flex-wrap: wrap;
      gap: 5px 18px;
      font-size: 11px;
      color: #888;
    }
    .contact-row .item {
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .contact-row .ic { color: #bbb; }
    .contact-row .ic svg { display: block; }

    /* ─── Section Layout ─── */
    .section {
      margin-bottom: 32px;
      display: flex;
      gap: 35px;
    }
    .section-label {
      flex: 0 0 130px;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #aaa;
      margin: 0;
      font-weight: 500;
      padding-top: 2px;
    }
    .section-body { flex: 1; }

    .entry { margin-bottom: 22px; }
    .entry:last-child { margin-bottom: 0; }
    .entry-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .entry-title {
      font-size: 15px;
      font-weight: 500;
      margin: 0;
      color: #111;
    }
    .entry-sub {
      font-size: 13px;
      color: #777;
      margin: 2px 0 0 0;
    }
    .entry-date {
      font-size: 11px;
      color: #bbb;
      white-space: nowrap;
    }
    .entry-desc {
      font-size: 12.5px;
      line-height: 1.7;
      color: #555;
      margin: 8px 0 0;
      padding-inline-start: 14px;
    }
    .entry-desc li { margin-bottom: 3px; }

    .summary-text {
      font-size: 13px;
      line-height: 1.7;
      color: #555;
      margin: 0;
    }

    .skills-inline {
      font-size: 12.5px;
      color: #555;
      margin-bottom: 12px;
    }
    .skills-inline strong {
      font-weight: 500;
      color: #333;
    }
    
    .sep {
      border: none;
      border-top: 1px solid #eee;
      margin: 0 0 32px 0;
    }
  </style>
</head>
<body class="lang-<%= data.language %>">
  <div class="page minimal-resume">
    <div class="header">
      <h1><%= data.fullName || '' %></h1>
      <h2><%= data.jobTitle || '' %></h2>
      <div class="contact-row">
        <% if (data.email) { %><span class="item"><span class="ic"><%- icon('email') %></span> <%= data.email %></span><% } %>
        <% if (data.phone) { %><span class="item"><span class="ic"><%- icon('phone') %></span> <span dir="ltr"><%= data.phone %></span></span><% } %>
        <% if (data.location) { %><span class="item"><span class="ic"><%- icon('location') %></span> <%= data.location %></span><% } %>
        <% if (data.socialLinks && data.socialLinks.length > 0) { data.socialLinks.forEach(link => { %>
          <span class="item"><span class="ic"><%- icon(link.name) %></span> <%= link.url %></span>
        <% }) } %>
      </div>
    </div>

    <hr class="sep">

    <% if (data.summary) { %>
    <div class="section">
      <h3 class="section-label"><%= data.language === 'en' ? 'Profile' : 'پروفایل' %></h3>
      <div class="section-body">
        <p class="summary-text"><%= data.summary %></p>
      </div>
    </div>
    <% } %>

    <% if (data.experience && data.experience.length > 0) { %>
    <div class="section">
      <h3 class="section-label"><%= data.language === 'en' ? 'Experience' : 'تجربیات' %></h3>
      <div class="section-body">
        <% data.experience.forEach(exp => { %>
          <div class="entry">
            <div class="entry-row">
              <p class="entry-title"><%= exp.title %></p>
              <span class="entry-date"><%= exp.date %></span>
            </div>
            <p class="entry-sub"><%= exp.company %></p>
            <ul class="entry-desc">
              <% (exp.descriptions || []).forEach(desc => { %><li><%= desc %></li><% }) %>
            </ul>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <% if (data.education && data.education.length > 0) { %>
    <div class="section">
      <h3 class="section-label"><%= data.language === 'en' ? 'Education' : 'تحصیلات' %></h3>
      <div class="section-body">
        <% data.education.forEach(edu => { %>
          <div class="entry">
            <div class="entry-row">
              <p class="entry-title"><%= edu.degree %></p>
              <span class="entry-date"><%= edu.date %></span>
            </div>
            <p class="entry-sub"><%= edu.university %></p>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <% if (data.skills && data.skills.length > 0) { %>
    <div class="section">
      <h3 class="section-label"><%= data.language === 'en' ? 'Skills' : 'مهارت‌ها' %></h3>
      <div class="section-body">
        <% data.skills.forEach(skillGroup => { %>
          <div class="skills-inline">
            <strong><%= skillGroup.category %>:</strong> <%= skillGroup.items.join(' · ') %>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <% if (data.projects && data.projects.length > 0) { %>
    <div class="section">
      <h3 class="section-label"><%= data.language === 'en' ? 'Projects' : 'پروژه‌ها' %></h3>
      <div class="section-body">
        <% data.projects.forEach(proj => { %>
          <div class="entry">
            <div class="entry-row">
              <p class="entry-title"><%= proj.name %></p>
              <% if (proj.link) { %><span class="entry-date"><%= proj.link %></span><% } %>
            </div>
            <p class="entry-sub"><%= proj.role %><% if (proj.techStack) { %> · <%= proj.techStack %><% } %></p>
            <ul class="entry-desc">
              <% (proj.descriptions || []).forEach(desc => { %><li><%= desc %></li><% }) %>
            </ul>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <% if (data.knownLanguages && data.knownLanguages.length > 0) { %>
    <div class="section">
      <h3 class="section-label"><%= data.language === 'en' ? 'Languages' : 'زبان‌ها' %></h3>
      <div class="section-body">
        <% data.knownLanguages.forEach(lang => { %>
          <div class="skills-inline"><strong><%= lang.name %></strong> — <%= lang.level %></div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</body>
</html>
