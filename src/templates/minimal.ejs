<!DOCTYPE html>
<html lang="<%= data.language === 'en' ? 'en' : 'fa' %>">
<head>
  <meta charset="UTF-8">
  <title>Resume - Minimal</title>
  <%- include('styles') %>
  <style>
    .minimal-resume {
      padding: 60px;
      max-width: 210mm;
      margin: auto;
      font-family: var(--font-en-body);
      color: #333;
    }
    .header {
      margin-bottom: 40px;
    }
    .header h1 {
      font-size: 42px;
      font-weight: 300;
      margin: 0;
      letter-spacing: -1px;
    }
    .header h2 {
      font-size: 16px;
      color: #777;
      margin: 5px 0 20px;
      font-weight: 400;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .contact-info {
      font-size: 12px;
      color: #999;
      line-height: 1.8;
    }
    .section {
      margin-bottom: 40px;
      display: flex;
      gap: 40px;
    }
    .section-title {
      flex: 0 0 150px;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #999;
      margin: 0;
      font-weight: 500;
    }
    .section-content {
      flex: 1;
    }
    .item {
      margin-bottom: 25px;
    }
    .item-header {
      margin-bottom: 5px;
    }
    .item-title {
      font-size: 16px;
      font-weight: 500;
      margin: 0;
    }
    .item-subtitle {
      font-size: 14px;
      color: #666;
    }
    .item-date {
      font-size: 12px;
      color: #999;
      float: right;
    }
    .item-desc {
      font-size: 13px;
      line-height: 1.6;
      color: #555;
      margin: 10px 0 0;
      padding-inline-start: 15px;
    }
    .skills-group {
      margin-bottom: 15px;
    }
    .skills-group strong {
      font-weight: 500;
      display: block;
      margin-bottom: 5px;
      font-size: 14px;
    }
    .skills-list {
      font-size: 13px;
      color: #666;
    }
  </style>
</head>
<body class="lang-<%= data.language %>">
  <div class="page minimal-resume">
    <div class="header">
      <h1><%= data.fullName %></h1>
      <h2><%= data.jobTitle %></h2>
      <div class="contact-info">
        <% if (data.email) { %><span><%= data.email %></span> | <% } %>
        <% if (data.phone) { %><span dir="ltr"><%= data.phone %></span> | <% } %>
        <% if (data.location) { %><span><%= data.location %></span><% } %>
      </div>
    </div>

    <% if (data.summary) { %>
    <div class="section">
      <h3 class="section-title"><%= data.language === 'en' ? 'Profile' : 'پروفایل' %></h3>
      <div class="section-content">
        <p style="font-size: 14px; line-height: 1.6; margin:0; color:#555;"><%= data.summary %></p>
      </div>
    </div>
    <% } %>

    <% if (data.experience && data.experience.length > 0) { %>
    <div class="section">
      <h3 class="section-title"><%= data.language === 'en' ? 'Experience' : 'تجربیات' %></h3>
      <div class="section-content">
        <% data.experience.forEach(exp => { %>
          <div class="item">
            <div class="item-header">
              <span class="item-date"><%= exp.date %></span>
              <p class="item-title"><%= exp.title %></p>
              <span class="item-subtitle"><%= exp.company %></span>
            </div>
            <ul class="item-desc">
              <% exp.descriptions.forEach(desc => { %><li><%= desc %></li><% }) %>
            </ul>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <% if (data.education && data.education.length > 0) { %>
    <div class="section">
      <h3 class="section-title"><%= data.language === 'en' ? 'Education' : 'تحصیلات' %></h3>
      <div class="section-content">
        <% data.education.forEach(edu => { %>
          <div class="item">
            <div class="item-header">
              <span class="item-date"><%= edu.date %></span>
              <p class="item-title"><%= edu.degree %></p>
              <span class="item-subtitle"><%= edu.university %></span>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

  </div>
</body>
</html>
