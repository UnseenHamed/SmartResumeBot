<!DOCTYPE html>
<html lang="<%= data.language === 'en' ? 'en' : 'fa' %>">

<head>
  <meta charset="UTF-8">
  <title>Resume — Modern</title>
  <%- include('styles') %>
    <style>
      .modern-resume {
        padding: 0;
        display: grid;
        grid-template-columns: 290px 1fr;
        min-height: 297mm;
      }

      /* ─── Sidebar ─── */
      .sidebar {
        background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
        color: #e2e8f0;
        padding: 50px 32px;
        position: relative;
      }

      .sidebar::before {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        width: 4px;
        background: linear-gradient(180deg, #3b82f6, #8b5cf6);
      }

      body.lang-en .sidebar::before {
        right: 0;
      }

      body.lang-fa .sidebar::before {
        left: 0;
      }

      .sidebar .avatar-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        font-size: 36px;
        font-weight: 700;
        color: white;
        text-transform: uppercase;
        box-shadow: 0 4px 20px rgba(59, 130, 246, 0.3);
      }

      .sidebar .name {
        font-size: 24px;
        font-weight: 700;
        color: #ffffff;
        margin: 0 0 6px 0;
        line-height: 1.2;
        text-align: center;
      }

      .sidebar .job-title {
        font-size: 12px;
        color: #93c5fd;
        margin: 0 0 32px 0;
        font-weight: 400;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        text-align: center;
      }

      .sidebar .section-title {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #60a5fa;
        margin: 28px 0 14px 0;
        padding-bottom: 8px;
        border-bottom: 1px solid rgba(96, 165, 250, 0.2);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .sidebar .section-title::before {
        content: '';
        width: 3px;
        height: 12px;
        background: #60a5fa;
        border-radius: 2px;
      }

      .sidebar .section-title:first-of-type {
        margin-top: 0;
      }

      .contact-item {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 11px;
        font-size: 12px;
        line-height: 1.5;
        color: #cbd5e1;
      }

      .contact-item .ic {
        flex-shrink: 0;
        margin-top: 2px;
        color: #60a5fa;
        width: 16px;
        height: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .contact-item .ic svg {
        display: block;
      }

      .contact-item span:last-child {
        word-break: break-word;
      }

      .skill-group {
        margin-bottom: 16px;
      }

      .skill-group:last-child {
        margin-bottom: 0;
      }

      .skill-group-title {
        font-size: 12px;
        font-weight: 600;
        color: #f1f5f9;
        margin: 0 0 8px 0;
      }

      .skill-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
      }

      .skill-tag {
        background: rgba(96, 165, 250, 0.12);
        color: #93c5fd;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 500;
        border: 1px solid rgba(96, 165, 250, 0.15);
      }

      .lang-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 12px;
        margin-bottom: 10px;
        color: #cbd5e1;
      }

      .lang-item .level {
        color: #93c5fd;
        font-size: 11px;
        background: rgba(96, 165, 250, 0.12);
        padding: 2px 8px;
        border-radius: 10px;
      }

      /* ─── Main Content ─── */
      .main-content {
        padding: 50px 44px;
      }

      .main-content .header {
        margin-bottom: 28px;
        padding-bottom: 24px;
        border-bottom: 2px solid #f1f5f9;
      }

      .main-content .header h1 {
        margin: 0;
        font-size: 32px;
        color: var(--text-dark);
        font-weight: 700;
        letter-spacing: -0.5px;
      }

      .main-content .header h2 {
        margin: 6px 0 0 0;
        font-size: 15px;
        color: var(--primary-color);
        font-weight: 500;
      }

      .main-section-title {
        font-size: 15px;
        color: var(--text-dark);
        border-bottom: 2px solid var(--primary-color);
        padding-bottom: 8px;
        margin: 32px 0 18px 0;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .main-section-title::before {
        content: '';
        width: 4px;
        height: 16px;
        background: var(--primary-color);
        border-radius: 2px;
      }

      .main-section-title:first-of-type {
        margin-top: 0;
      }

      .summary-box {
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        padding: 16px 20px;
        border-inline-start: 4px solid var(--primary-color);
        border-radius: 0 8px 8px 0;
        font-size: 13px;
        line-height: 1.7;
        color: #475569;
        margin-bottom: 10px;
      }

      .timeline-item {
        margin-bottom: 22px;
        position: relative;
        padding-inline-start: 20px;
      }

      .timeline-item::before {
        content: '';
        position: absolute;
        width: 2px;
        background: #e2e8f0;
        top: 8px;
        bottom: -8px;
      }

      body.lang-en .timeline-item::before {
        left: 0;
      }

      body.lang-fa .timeline-item::before {
        right: 0;
      }

      .timeline-item:last-child::before {
        display: none;
      }

      .timeline-item::after {
        content: '';
        position: absolute;
        width: 10px;
        height: 10px;
        background: var(--primary-color);
        border-radius: 50%;
        top: 6px;
        border: 2px solid white;
        box-shadow: 0 0 0 2px var(--primary-color);
      }

      body.lang-en .timeline-item::after {
        left: -5px;
      }

      body.lang-fa .timeline-item::after {
        right: -5px;
      }

      .timeline-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 3px;
      }

      .timeline-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-dark);
        margin: 0;
      }

      .timeline-subtitle {
        font-size: 13px;
        color: var(--primary-color);
        font-weight: 500;
        margin: 2px 0 0 0;
      }

      .timeline-date {
        font-size: 11px;
        color: var(--text-light);
        white-space: nowrap;
        background: #f1f5f9;
        padding: 3px 10px;
        border-radius: 10px;
        font-weight: 500;
      }

      .timeline-desc {
        margin: 8px 0 0 0;
        font-size: 12.5px;
        line-height: 1.6;
        color: #475569;
      }

      .timeline-desc ul {
        margin: 4px 0;
        padding-inline-start: 18px;
      }

      .timeline-desc li {
        margin-bottom: 3px;
      }
    </style>
</head>

<body class="lang-<%= data.language %>">
  <div class="page modern-resume">

    <!-- Sidebar -->
    <div class="sidebar">
      <div class="avatar-circle">
        <%= (data.fullName || '?' ).charAt(0) %>
      </div>
      <h1 class="name">
        <%= data.fullName || '' %>
      </h1>
      <p class="job-title">
        <%= data.jobTitle || '' %>
      </p>

      <!-- Contact -->
      <h3 class="section-title">
        <%= data.language==='en' ? 'Contact' : 'تماس' %>
      </h3>

      <% if (data.email) { %>
        <div class="contact-item">
          <span class="ic"><%- icon('email') %></span>
          <span>
            <%= data.email %>
          </span>
        </div>
        <% } %>
          <% if (data.phone) { %>
            <div class="contact-item">
              <span class="ic"><%- icon('phone') %></span>
              <span dir="ltr">
                <%= data.phone %>
              </span>
            </div>
            <% } %>
              <% if (data.location) { %>
                <div class="contact-item">
                  <span class="ic"><%- icon('location') %></span>
                  <span>
                    <%= data.location %>
                  </span>
                </div>
                <% } %>
                  <% if (data.socialLinks && data.socialLinks.length> 0) { %>
                    <% data.socialLinks.forEach(link=> { %>
                      <div class="contact-item">
                        <span class="ic"><%- icon(link.name) %></span>
                        <span>
                          <%= link.url %>
                        </span>
                      </div>
                      <% }) %>
                        <% } %>

                          <!-- Skills -->
                          <% if (data.skills && data.skills.length> 0) { %>
                            <h3 class="section-title">
                              <%= data.language==='en' ? 'Skills' : 'مهارت‌ها' %>
                            </h3>
                            <% data.skills.forEach(skillGroup=> { %>
                              <div class="skill-group">
                                <p class="skill-group-title">
                                  <%= skillGroup.category %>
                                </p>
                                <div class="skill-tags">
                                  <% skillGroup.items.forEach(item=> { %>
                                    <span class="skill-tag">
                                      <%= item %>
                                    </span>
                                    <% }) %>
                                </div>
                              </div>
                              <% }) %>
                                <% } %>

                                  <!-- Languages -->
                                  <% if (data.knownLanguages && data.knownLanguages.length> 0) { %>
                                    <h3 class="section-title">
                                      <%= data.language==='en' ? 'Languages' : 'زبان‌ها' %>
                                    </h3>
                                    <% data.knownLanguages.forEach(lang=> { %>
                                      <div class="lang-item">
                                        <span>
                                          <%= lang.name %>
                                        </span>
                                        <span class="level">
                                          <%= lang.level %>
                                        </span>
                                      </div>
                                      <% }) %>
                                        <% } %>
    </div>

    <!-- Main Content -->
    <div class="main-content">
      <div class="header">
        <h1>
          <%= data.fullName || '' %>
        </h1>
        <h2>
          <%= data.jobTitle || '' %>
        </h2>
      </div>

      <% if (data.summary) { %>
        <div class="summary-box">
          <%= data.summary %>
        </div>
        <% } %>

          <!-- Experience -->
          <% if (data.experience && data.experience.length> 0) { %>
            <h3 class="main-section-title">
              <%= data.language==='en' ? 'Experience' : 'سوابق کاری' %>
            </h3>
            <% data.experience.forEach(exp=> { %>
              <div class="timeline-item">
                <div class="timeline-header">
                  <h4 class="timeline-title">
                    <%= exp.title %>
                  </h4>
                  <span class="timeline-date">
                    <%= exp.date %>
                  </span>
                </div>
                <p class="timeline-subtitle">
                  <%= exp.company %>
                </p>
                <div class="timeline-desc">
                  <ul>
                    <% (exp.descriptions || []).forEach(desc=> { %><li>
                        <%= desc %>
                      </li>
                      <% }) %>
                  </ul>
                </div>
              </div>
              <% }) %>
                <% } %>

                  <!-- Projects -->
                  <% if (data.projects && data.projects.length> 0) { %>
                    <h3 class="main-section-title">
                      <%= data.language==='en' ? 'Projects' : 'پروژه‌ها' %>
                    </h3>
                    <% data.projects.forEach(proj=> { %>
                      <div class="timeline-item">
                        <div class="timeline-header">
                          <h4 class="timeline-title">
                            <%= proj.name %>
                          </h4>
                          <% if (proj.link) { %><span class="timeline-date">
                              <%= proj.link %>
                            </span>
                            <% } %>
                        </div>
                        <p class="timeline-subtitle">
                          <%= proj.role %>
                            <% if (proj.techStack) { %> · <%= proj.techStack %>
                                <% } %>
                        </p>
                        <div class="timeline-desc">
                          <ul>
                            <% (proj.descriptions || []).forEach(desc=> { %><li>
                                <%= desc %>
                              </li>
                              <% }) %>
                          </ul>
                        </div>
                      </div>
                      <% }) %>
                        <% } %>

                          <!-- Education -->
                          <% if (data.education && data.education.length> 0) { %>
                            <h3 class="main-section-title">
                              <%= data.language==='en' ? 'Education' : 'تحصیلات' %>
                            </h3>
                            <% data.education.forEach(edu=> { %>
                              <div class="timeline-item">
                                <div class="timeline-header">
                                  <h4 class="timeline-title">
                                    <%= edu.degree %>
                                  </h4>
                                  <span class="timeline-date">
                                    <%= edu.date %>
                                  </span>
                                </div>
                                <p class="timeline-subtitle">
                                  <%= edu.university %>
                                </p>
                              </div>
                              <% }) %>
                                <% } %>
    </div>
  </div>
</body>

</html>