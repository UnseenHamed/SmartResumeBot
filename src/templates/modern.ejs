<!DOCTYPE html>
<html lang="<%= data.language === 'en' ? 'en' : 'fa' %>">
<head>
  <meta charset="UTF-8">
  <title>Resume — Modern</title>
  <%- include('styles') %>
  <style>
    .modern-resume {
      padding: 0;
      display: grid;
      grid-template-columns: 280px 1fr;
      min-height: 297mm;
    }
    
    /* ─── Sidebar ─── */
    .sidebar {
      background: #1e293b;
      color: #e2e8f0;
      padding: 45px 30px;
    }
    .sidebar .name {
      font-size: 26px;
      font-weight: 700;
      color: #ffffff;
      margin: 0 0 5px 0;
      line-height: 1.2;
    }
    .sidebar .job-title {
      font-size: 13px;
      color: #94a3b8;
      margin: 0 0 30px 0;
      font-weight: 400;
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }
    
    .sidebar .section-title {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #60a5fa;
      margin: 30px 0 15px 0;
      padding-bottom: 8px;
      border-bottom: 1px solid #334155;
      font-weight: 600;
    }
    .sidebar .section-title:first-of-type { margin-top: 0; }

    .contact-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 12px;
      font-size: 12px;
      line-height: 1.5;
      color: #cbd5e1;
    }
    .contact-item .ic { 
      flex-shrink: 0; 
      margin-top: 2px; 
      color: #60a5fa; 
    }
    .contact-item .ic svg { display: block; }

    .skill-group { margin-bottom: 18px; }
    .skill-group-title {
      font-size: 12px;
      font-weight: 600;
      color: #f1f5f9;
      margin: 0 0 8px 0;
    }
    .skill-tags { display: flex; flex-wrap: wrap; gap: 5px; }
    .skill-tag {
      background: #334155;
      color: #e2e8f0;
      padding: 3px 10px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 500;
    }

    .lang-item {
      display: flex;
      justify-content: space-between;
      font-size: 13px;
      margin-bottom: 8px;
    }
    .lang-item .level { color: #94a3b8; font-size: 12px; }

    /* ─── Main Content ─── */
    .main-content {
      padding: 45px 40px;
    }
    .main-content .header {
      margin-bottom: 25px;
    }
    .main-content .header h1 {
      margin: 0;
      font-size: 34px;
      color: var(--primary-color);
      font-weight: 700;
    }
    .main-content .header h2 {
      margin: 5px 0 0 0;
      font-size: 16px;
      color: var(--text-light);
      font-weight: 400;
    }

    .main-section-title {
      font-size: 16px;
      color: var(--primary-color);
      border-bottom: 2px solid var(--primary-color);
      padding-bottom: 6px;
      margin: 30px 0 18px 0;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .summary-box {
      background: #f8fafc;
      padding: 15px 18px;
      border-inline-start: 4px solid var(--primary-color);
      border-radius: 0 6px 6px 0;
      font-size: 13px;
      line-height: 1.7;
      color: #475569;
      margin-bottom: 10px;
    }

    .timeline-item { margin-bottom: 22px; }
    .timeline-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 3px;
    }
    .timeline-title {
      font-size: 15px;
      font-weight: 600;
      color: var(--text-dark);
      margin: 0;
    }
    .timeline-subtitle {
      font-size: 13px;
      color: var(--primary-color);
      font-weight: 500;
      margin: 2px 0 0 0;
    }
    .timeline-date {
      font-size: 12px;
      color: var(--text-light);
      white-space: nowrap;
    }
    .timeline-desc {
      margin: 6px 0 0 0;
      font-size: 13px;
      line-height: 1.6;
      color: #475569;
    }
    .timeline-desc ul {
      margin: 4px 0;
      padding-inline-start: 18px;
    }
    .timeline-desc li { margin-bottom: 3px; }
  </style>
</head>
<body class="lang-<%= data.language %>">
  <div class="page modern-resume">
    
    <!-- Sidebar -->
    <div class="sidebar">
      <h1 class="name"><%= data.fullName || '' %></h1>
      <p class="job-title"><%= data.jobTitle || '' %></p>

      <!-- Contact -->
      <h3 class="section-title"><%= data.language === 'en' ? 'Contact' : 'تماس' %></h3>
      
      <% if (data.email) { %>
      <div class="contact-item">
        <span class="ic"><%- icon('email') %></span>
        <span><%= data.email %></span>
      </div>
      <% } %>
      <% if (data.phone) { %>
      <div class="contact-item">
        <span class="ic"><%- icon('phone') %></span>
        <span dir="ltr"><%= data.phone %></span>
      </div>
      <% } %>
      <% if (data.location) { %>
      <div class="contact-item">
        <span class="ic"><%- icon('location') %></span>
        <span><%= data.location %></span>
      </div>
      <% } %>
      <% if (data.socialLinks && data.socialLinks.length > 0) { %>
        <% data.socialLinks.forEach(link => { %>
        <div class="contact-item">
          <span class="ic"><%- icon(link.name) %></span>
          <span><%= link.url %></span>
        </div>
        <% }) %>
      <% } %>

      <!-- Skills -->
      <% if (data.skills && data.skills.length > 0) { %>
      <h3 class="section-title"><%= data.language === 'en' ? 'Skills' : 'مهارت‌ها' %></h3>
      <% data.skills.forEach(skillGroup => { %>
        <div class="skill-group">
          <p class="skill-group-title"><%= skillGroup.category %></p>
          <div class="skill-tags">
            <% skillGroup.items.forEach(item => { %>
              <span class="skill-tag"><%= item %></span>
            <% }) %>
          </div>
        </div>
      <% }) %>
      <% } %>

      <!-- Languages -->
      <% if (data.knownLanguages && data.knownLanguages.length > 0) { %>
      <h3 class="section-title"><%= data.language === 'en' ? 'Languages' : 'زبان‌ها' %></h3>
      <% data.knownLanguages.forEach(lang => { %>
        <div class="lang-item">
          <span><%= lang.name %></span>
          <span class="level"><%= lang.level %></span>
        </div>
      <% }) %>
      <% } %>
    </div>

    <!-- Main Content -->
    <div class="main-content">
      <div class="header">
        <h1><%= data.fullName || '' %></h1>
        <h2><%= data.jobTitle || '' %></h2>
      </div>

      <% if (data.summary) { %>
      <div class="summary-box"><%= data.summary %></div>
      <% } %>

      <!-- Experience -->
      <% if (data.experience && data.experience.length > 0) { %>
      <h3 class="main-section-title"><%= data.language === 'en' ? 'Experience' : 'سوابق کاری' %></h3>
      <% data.experience.forEach(exp => { %>
        <div class="timeline-item">
          <div class="timeline-header">
            <h4 class="timeline-title"><%= exp.title %></h4>
            <span class="timeline-date"><%= exp.date %></span>
          </div>
          <p class="timeline-subtitle"><%= exp.company %></p>
          <div class="timeline-desc">
            <ul>
              <% (exp.descriptions || []).forEach(desc => { %><li><%= desc %></li><% }) %>
            </ul>
          </div>
        </div>
      <% }) %>
      <% } %>

      <!-- Projects -->
      <% if (data.projects && data.projects.length > 0) { %>
      <h3 class="main-section-title"><%= data.language === 'en' ? 'Projects' : 'پروژه‌ها' %></h3>
      <% data.projects.forEach(proj => { %>
        <div class="timeline-item">
          <div class="timeline-header">
            <h4 class="timeline-title"><%= proj.name %></h4>
            <% if (proj.link) { %><span class="timeline-date"><%= proj.link %></span><% } %>
          </div>
          <p class="timeline-subtitle"><%= proj.role %><% if (proj.techStack) { %> · <%= proj.techStack %><% } %></p>
          <div class="timeline-desc">
            <ul>
              <% (proj.descriptions || []).forEach(desc => { %><li><%= desc %></li><% }) %>
            </ul>
          </div>
        </div>
      <% }) %>
      <% } %>

      <!-- Education -->
      <% if (data.education && data.education.length > 0) { %>
      <h3 class="main-section-title"><%= data.language === 'en' ? 'Education' : 'تحصیلات' %></h3>
      <% data.education.forEach(edu => { %>
        <div class="timeline-item">
          <div class="timeline-header">
            <h4 class="timeline-title"><%= edu.degree %></h4>
            <span class="timeline-date"><%= edu.date %></span>
          </div>
          <p class="timeline-subtitle"><%= edu.university %></p>
        </div>
      <% }) %>
      <% } %>
    </div>
  </div>
</body>
</html>
