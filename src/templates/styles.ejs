  /* ─── Multi-Page Print System ─── */
  @page {
    size: A4;
    margin: 0;
  }

  @media print {

    html,
    body {
      width: 210mm;
      height: auto;
    }

    .page {
      page-break-after: always;
      page-break-inside: avoid;
    }

    .page:last-child {
      page-break-after: auto;
    }

    /* Prevent breaking inside these elements */
    .timeline-item,
    .timeline-entry,
    .entry,
    .skill-group,
    .skill-block,
    .lang-entry,
    .contact-item,
    .section,
