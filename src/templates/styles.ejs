      break-inside: avoid;
    }

    /* Section titles should stay with their content */
    .main-section-title,
    .section-title,
    .section-label {
      page-break-after: avoid;
      break-after: avoid;
    }

    /* Keep headers with following content */
    h1,
    h2,
    h3,
    h4 {
      page-break-after: avoid;
      break-after: avoid;
    }
  }

