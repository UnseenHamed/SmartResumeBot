    --bg-color: #ffffff;
    --bg-alt: #f3f4f6;
    --border-color: #e5e7eb;
  }

  /* ─── Base Reset ─── */
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    padding: 0;
    background-color: var(--bg-color);
    color: var(--text-dark);
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  body.lang-en {
    font-family: var(--font-en-body);
    direction: ltr;
